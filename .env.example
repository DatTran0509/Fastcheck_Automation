# ─────────────────────────────────────────────────────────────────────────────
# FastCheck — example environment. Copy to `.env` and adjust.
#   cp .env.example .env
# packages/config validates these with zod and FAILS FAST if a required one is
# missing/invalid (no half-broken runtime — see docs/tech-stack.md). Never commit .env (INV-12).
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# pino level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Infra (matches docker-compose.yml) ───────────────────────────────────────
DATABASE_URL=postgres://fastcheck:fastcheck@localhost:5432/fastcheck
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://fastcheck:fastcheck@localhost:5672

# ── Cookie encryption (INV-12) ───────────────────────────────────────────────
# AES-256-GCM key, base64-encoded 32 bytes. Generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# COOKIE_KEY_ID lets us rotate keys: old ciphertext keeps its old key id.
COOKIE_ENC_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
COOKIE_KEY_ID=k1
# (Tuỳ chọn) Khoá CŨ để xoay khoá — JSON {"<keyId>":"<base64 32 byte>"}. Giữ để giải mã cookie tạo bằng khoá cũ.
# COOKIE_ENC_KEYS={"k0":"<base64-32-byte-cua-khoa-cu>"}

# ── FastCheck API (apps/api) ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3001
# Result cache TTLs (seconds). INV: TTL LIVE < TTL DEAD; INCONCLUSIVE is never cached.
RESULT_CACHE_TTL_LIVE_SECONDS=300
RESULT_CACHE_TTL_DEAD_SECONDS=900
# Per-client rate limit (requests/minute) — anti-spam at the edge.
RATE_LIMIT_PER_MINUTE=120

# ── Orchestrator (apps/orchestrator) ─────────────────────────────────────────
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=3002
# Shared secret stations must present over WSS to connect (INV-12). Use a long random string.
WS_AUTH_TOKEN=dev-only-change-me
# RabbitMQ consumer prefetch (backpressure). Đặt BẰNG tổng công suất station (INV-10). Load test
# (scripts/loadtest) đo khác biệt khi prefetch > pool size rồi chỉnh về bằng nhau.
ORCHESTRATOR_PREFETCH=20

# ── Phase 4: phát hiện station chết & thu hồi job (INV-15) ────────────────────
# Station ping ~10s. Quá HEARTBEAT_TIMEOUT_MS không ping → OFFLINE + thu hồi mọi job RUNNING (re-queue).
HEARTBEAT_TIMEOUT_MS=30000
# Chu kỳ cron quét station quá hạn heartbeat.
STATION_MONITOR_INTERVAL_MS=5000

# ── Phase 5: circuit breaker theo platform (§10.6) ────────────────────────────
# Tỷ lệ BLOCKED/lỗi trong CIRCUIT_WINDOW_SECONDS (cần ≥ MIN_SAMPLES mẫu) ≥ THRESHOLD → mở circuit;
# API trả 503 + Retry-After = CIRCUIT_COOLDOWN_SECONDS; hết cooldown → HALF_OPEN thăm dò rồi đóng/mở lại.
CIRCUIT_WINDOW_SECONDS=60
CIRCUIT_MIN_SAMPLES=5
CIRCUIT_BLOCK_THRESHOLD=0.5
CIRCUIT_COOLDOWN_SECONDS=30

# ── Phase 5: observability / dashboard ────────────────────────────────────────
# Chu kỳ cập nhật gauge độ sâu queue vào /metrics; chu kỳ SSE dashboard; cửa sổ (phút) tính tỷ lệ kết quả.
QUEUE_METRICS_INTERVAL_MS=5000
DASHBOARD_STREAM_INTERVAL_MS=2000
DASHBOARD_RATIO_WINDOW_MINUTES=60

# ── Phase 3: auto-switch / profile lifecycle / rate-limit ────────────────────
# Số lần re-queue tối đa trước khi vào DLQ (chống switch vô hạn). Backoff = base*2^retry (cap max).
ORCHESTRATOR_MAX_RETRIES=3
RETRY_BACKOFF_BASE_MS=2000
RETRY_BACKOFF_MAX_MS=60000
# health_score: trừ khi challenge/block, cộng khi thành công; consecutive_fails>=ngưỡng → DEAD.
PROFILE_HEALTH_PENALTY=20
PROFILE_HEALTH_BUMP=5
PROFILE_DEAD_THRESHOLD=3
PROFILE_COOLDOWN_SECONDS=300
# Cảnh báo khi số profile khả dụng của platform <= ngưỡng (pool thấp).
PROFILE_POOL_LOW_WATERMARK=2
PROXY_BAN_THRESHOLD=5
# Cron dọn lease (profile IN_USE quá hạn → AVAILABLE).
LEASE_REAP_INTERVAL_MS=60000
LEASE_MINUTES=5
# Rate-limit token bucket (mặc định rộng để đường thường trong suốt; siết khi cần bảo vệ pool).
RATE_LIMIT_PROFILE_CAPACITY=20
RATE_LIMIT_PROFILE_REFILL_PER_SEC=5
RATE_LIMIT_PLATFORM_CAPACITY=200
RATE_LIMIT_PLATFORM_REFILL_PER_SEC=100

# ── Worker / Station (apps/worker — runs NATIVE on Windows) ──────────────────
# STATION_ID is a stable UUID identifying this machine in the `stations` table.
STATION_ID=00000000-0000-4000-8000-000000000001
STATION_NAME=dev-station
WORKER_MAX_CONCURRENCY=4
AGENT_VERSION=0.0.1
# Where the worker connects to reach the orchestrator WS gateway.
ORCHESTRATOR_WS_URL=ws://localhost:3002
HEARTBEAT_INTERVAL_MS=10000
# GemLogin integration mode: `fake` (default — runs end-to-end without GemLogin) or `real`.
GEMLOGIN_MODE=fake
# Only used when GEMLOGIN_MODE=real (GemLogin local API: CRUD profile + start/stop + CDP address).
GEMLOGIN_API_URL=http://localhost:1010
# Hard timeout mỗi job (INV-9, ≤2 phút). Quá hạn → INCONCLUSIVE + dọn tiến trình.
JOB_TIMEOUT_SECONDS=120

# ── Phase 4: process hygiene / giám sát tài nguyên (INV-9) ────────────────────
# Ngưỡng RAM (MB) một browser (cây tiến trình). Vượt → kill cây + giải phóng slot + trả profile.
BROWSER_RAM_LIMIT_MB=1500
RESOURCE_MONITOR_INTERVAL_SECONDS=5
# CHỈ fake mode: TTL (giây) của tiến trình "browser giả" (chống rò nếu quên đóng).
FAKE_BROWSER_TTL_SECONDS=300
# Giây chờ browser có tab 'page' (CDP) sau khi start, TRƯỚC khi DrissionPage attach. Chống race lần đầu mở
# profile MỚI: browser dựng lên mà kịch bản không thao tác gì, phải chạy lần 2. Tăng nếu máy trạm yếu.
BROWSER_CDP_READY_WAIT_SECONDS=30
# Đồng bộ danh sách profile GemLogin → server (§3).
PROFILE_SYNC_INTERVAL_SECONDS=60

# ── forward CDP an toàn (INV-12) — mặc định TẮT (chạy script login local) ──
# Dùng CHUNG cho worker (CdpTunnel bắc cầu CDP local GemLogin) và orchestrator (relay /cdp ghép cầu
# worker↔controller). Bật forward CHỈ khi cần điều khiển browser từ xa; BẮT BUỘC có token (bọc WSS + token,
# giữ trong mạng nội bộ/tunnel). Bật mà thiếu token → cả hai phía fail-fast (không phơi CDP trần).
CDP_FORWARD_ENABLED=false
# CDP_FORWARD_TOKEN=doi-thanh-token-dai-ngau-nhien
