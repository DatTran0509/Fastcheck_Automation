# ─────────────────────────────────────────────────────────────────────────────
# FastCheck — example environment. Copy to `.env` and adjust.
#   cp .env.example .env
# packages/config validates these with zod and FAILS FAST if a required one is
# missing/invalid (no half-broken runtime — see docs/tech-stack.md). Never commit .env (INV-12).
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# pino level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Infra (matches docker-compose.yml) ───────────────────────────────────────
DATABASE_URL=postgres://fastcheck:fastcheck@localhost:5432/fastcheck
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://fastcheck:fastcheck@localhost:5672

# ── Cookie encryption (INV-12) ───────────────────────────────────────────────
# AES-256-GCM key, base64-encoded 32 bytes. Generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# COOKIE_KEY_ID lets us rotate keys: old ciphertext keeps its old key id.
COOKIE_ENC_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
COOKIE_KEY_ID=k1
# (Tuỳ chọn) Khoá CŨ để xoay khoá — JSON {"<keyId>":"<base64 32 byte>"}. Giữ để giải mã cookie tạo bằng khoá cũ.
# COOKIE_ENC_KEYS={"k0":"<base64-32-byte-cua-khoa-cu>"}

# ── FastCheck API (apps/api) ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3001
# Result cache TTLs (seconds). INV: TTL LIVE < TTL DEAD; INCONCLUSIVE is never cached.
RESULT_CACHE_TTL_LIVE_SECONDS=300
RESULT_CACHE_TTL_DEAD_SECONDS=900
# Per-client rate limit (requests/minute) — anti-spam at the edge.
RATE_LIMIT_PER_MINUTE=120

# ── Orchestrator (apps/orchestrator) ─────────────────────────────────────────
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=3002
# Shared secret stations must present over WSS to connect (INV-12). Use a long random string.
WS_AUTH_TOKEN=dev-only-change-me
# RabbitMQ consumer prefetch (backpressure). Tuned against station capacity in Phase 4 (INV-10).
ORCHESTRATOR_PREFETCH=20

# ── Worker / Station (apps/worker — runs NATIVE on Windows) ──────────────────
# STATION_ID is a stable UUID identifying this machine in the `stations` table.
STATION_ID=00000000-0000-4000-8000-000000000001
STATION_NAME=dev-station
WORKER_MAX_CONCURRENCY=4
AGENT_VERSION=0.0.1
# Where the worker connects to reach the orchestrator WS gateway.
ORCHESTRATOR_WS_URL=ws://localhost:3002
HEARTBEAT_INTERVAL_MS=10000
# GemLogin integration mode: `fake` (default — runs end-to-end without GemLogin) or `real`.
GEMLOGIN_MODE=fake
# Only used when GEMLOGIN_MODE=real (GemLogin local API). Optional in fake mode.
GEMLOGIN_API_URL=http://localhost:1010
