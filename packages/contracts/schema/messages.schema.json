{
  "type": "object",
  "properties": {},
  "additionalProperties": false,
  "description": "FastCheck WS/queue message definitions",
  "definitions": {
    "ProfileConfig": {
      "type": "object",
      "properties": {
        "os_type": {
          "type": "string",
          "enum": [
            "Windows",
            "macOS",
            "Android",
            "IOS",
            "Linux"
          ],
          "default": "macOS"
        },
        "os_version": {
          "type": "string",
          "default": "macos13"
        },
        "browser_version": {
          "type": "string",
          "default": "141"
        },
        "startup_url": {
          "type": "string",
          "default": ""
        },
        "user_agent_mode": {
          "type": "string",
          "enum": [
            "auto",
            "custom"
          ],
          "default": "auto"
        },
        "user_agent": {
          "type": [
            "string",
            "null"
          ]
        },
        "country": {
          "type": "string",
          "default": "Vietnam"
        },
        "language": {
          "type": "string",
          "default": "vi,en"
        },
        "time_zone": {
          "type": "string",
          "default": "Asia/Ho_Chi_Minh"
        },
        "proxy_type": {
          "type": "string",
          "enum": [
            "none",
            "http",
            "https",
            "socks5"
          ],
          "default": "none"
        },
        "proxy": {
          "type": [
            "string",
            "null"
          ]
        },
        "web_rtc": {
          "type": "string",
          "enum": [
            "replace",
            "disabled"
          ],
          "default": "disabled"
        },
        "screen_resolution": {
          "type": "string",
          "enum": [
            "custom",
            "random"
          ],
          "default": "random"
        },
        "resolution": {
          "type": "string",
          "default": "1920x1080"
        },
        "canvas": {
          "type": "string",
          "enum": [
            "real",
            "noise"
          ],
          "default": "noise"
        },
        "webgl_image": {
          "$ref": "#/definitions/ProfileConfig/properties/canvas",
          "default": "noise"
        },
        "webgl_metadata": {
          "type": "string",
          "enum": [
            "custom",
            "real",
            "random"
          ],
          "default": "custom"
        },
        "webgl_vendor": {
          "type": [
            "string",
            "null"
          ]
        },
        "webgl_renderer": {
          "type": [
            "string",
            "null"
          ]
        },
        "audio_context": {
          "$ref": "#/definitions/ProfileConfig/properties/canvas",
          "default": "noise"
        },
        "media_device": {
          "$ref": "#/definitions/ProfileConfig/properties/canvas",
          "default": "noise"
        },
        "client_rects": {
          "$ref": "#/definitions/ProfileConfig/properties/canvas",
          "default": "noise"
        },
        "fonts": {
          "type": "string",
          "enum": [
            "default",
            "custom"
          ],
          "default": "default"
        },
        "speech_voices": {
          "$ref": "#/definitions/ProfileConfig/properties/canvas",
          "default": "noise"
        },
        "ssl": {
          "$ref": "#/definitions/ProfileConfig/properties/canvas",
          "default": "real"
        },
        "plugins": {
          "$ref": "#/definitions/ProfileConfig/properties/canvas",
          "default": "noise"
        },
        "hardware_concurrency": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 10
        },
        "device_memory": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 10
        },
        "device_name_mode": {
          "type": "string",
          "enum": [
            "real",
            "custom"
          ],
          "default": "custom"
        },
        "device_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "mac_address_mode": {
          "$ref": "#/definitions/ProfileConfig/properties/device_name_mode",
          "default": "custom"
        },
        "mac_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "do_not_track": {
          "type": "string",
          "enum": [
            "default",
            "open",
            "close"
          ],
          "default": "open"
        },
        "flash": {
          "type": "string",
          "enum": [
            "accept",
            "decline"
          ],
          "default": "accept"
        },
        "port_scan_protection": {
          "type": "string",
          "enum": [
            "accept",
            "decline"
          ],
          "default": "accept"
        },
        "hardware_acceleration": {
          "type": "string",
          "enum": [
            "default",
            "accept",
            "decline"
          ],
          "default": "accept"
        }
      },
      "additionalProperties": false
    },
    "StationInfo": {
      "type": "object",
      "properties": {
        "station_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mac_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "ip_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "agent_version": {
          "type": "string",
          "minLength": 1
        },
        "max_concurrency": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "station_id",
        "name",
        "agent_version",
        "max_concurrency"
      ],
      "additionalProperties": false
    },
    "StationProfile": {
      "type": "object",
      "properties": {
        "gemlogin_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "platform": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "TIKTOK",
                "FACEBOOK",
                "TWITTER",
                "YOUTUBE"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "gem_status": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "gemlogin_profile_id"
      ],
      "additionalProperties": false
    },
    "RegisterMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "register"
        },
        "station": {
          "$ref": "#/definitions/StationInfo"
        }
      },
      "required": [
        "type",
        "station"
      ],
      "additionalProperties": false
    },
    "HeartbeatMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "heartbeat"
        },
        "station_id": {
          "type": "string",
          "format": "uuid"
        },
        "current_load": {
          "type": "integer",
          "minimum": 0
        },
        "ts": {
          "type": "string"
        },
        "ram_mb": {
          "type": [
            "number",
            "null"
          ]
        },
        "cpu_percent": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "required": [
        "type",
        "station_id",
        "current_load",
        "ts"
      ],
      "additionalProperties": false
    },
    "CommandAckMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "command_ack"
        },
        "command_id": {
          "type": "string",
          "format": "uuid"
        },
        "station_id": {
          "type": "string",
          "format": "uuid"
        },
        "ok": {
          "type": "boolean"
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "profile_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "type",
        "command_id",
        "station_id",
        "ok"
      ],
      "additionalProperties": false
    },
    "ProfileSyncMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "profile_sync"
        },
        "station_id": {
          "type": "string",
          "format": "uuid"
        },
        "profiles": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StationProfile"
          }
        },
        "all_gemlogin_ids": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "type",
        "station_id",
        "profiles"
      ],
      "additionalProperties": false
    },
    "JobResultMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "job_result"
        },
        "command_id": {
          "type": "string",
          "format": "uuid"
        },
        "trace_id": {
          "type": "string",
          "format": "uuid"
        },
        "job_id": {
          "type": "string",
          "format": "uuid"
        },
        "url_status": {
          "type": "string",
          "enum": [
            "LIVE",
            "DEAD",
            "INCONCLUSIVE"
          ]
        },
        "profile_health": {
          "type": "string",
          "enum": [
            "OK",
            "CHALLENGED",
            "BLOCKED",
            "THROTTLED"
          ]
        },
        "block_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "response_time_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "type",
        "command_id",
        "trace_id",
        "job_id",
        "url_status",
        "profile_health"
      ],
      "additionalProperties": false
    },
    "CookieRefreshMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "cookie_refresh"
        },
        "station_id": {
          "type": "string",
          "format": "uuid"
        },
        "profile_id": {
          "type": "string",
          "format": "uuid"
        },
        "gemlogin_profile_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "cookie": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "type",
        "station_id",
        "profile_id",
        "cookie"
      ],
      "additionalProperties": false
    },
    "JobProgressMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "job_progress"
        },
        "station_id": {
          "type": "string",
          "format": "uuid"
        },
        "trace_id": {
          "type": "string",
          "format": "uuid"
        },
        "job_id": {
          "type": "string",
          "format": "uuid"
        },
        "step": {
          "type": "string",
          "enum": [
            "OPEN_BROWSER",
            "LOGIN",
            "DETECT",
            "DONE"
          ]
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "ts": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "station_id",
        "trace_id",
        "job_id",
        "step",
        "ts"
      ],
      "additionalProperties": false
    },
    "RunCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "script.run"
        },
        "trace_id": {
          "type": "string",
          "format": "uuid"
        },
        "job_id": {
          "type": "string",
          "format": "uuid"
        },
        "target_url": {
          "type": "string"
        },
        "platform": {
          "type": "string",
          "enum": [
            "TIKTOK",
            "FACEBOOK",
            "TWITTER",
            "YOUTUBE"
          ]
        },
        "profile_id": {
          "type": "string",
          "format": "uuid"
        },
        "gemlogin_profile_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "cookie": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "trace_id",
        "job_id",
        "target_url",
        "platform",
        "profile_id",
        "cookie"
      ],
      "additionalProperties": false
    },
    "BrowserOpenCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "browser.open"
        },
        "profile_id": {
          "type": "string",
          "format": "uuid"
        },
        "gemlogin_profile_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "cookie": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "profile_id"
      ],
      "additionalProperties": false
    },
    "BrowserCloseCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "browser.close"
        },
        "profile_id": {
          "type": "string",
          "format": "uuid"
        },
        "gemlogin_profile_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "profile_id"
      ],
      "additionalProperties": false
    },
    "ProfileCreateCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "profile.create"
        },
        "platform": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "TIKTOK",
                "FACEBOOK",
                "TWITTER",
                "YOUTUBE"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "account_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "proxy": {
          "type": [
            "string",
            "null"
          ]
        },
        "config": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProfileConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "ProfileUpdateCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "profile.update"
        },
        "gemlogin_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "account_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "proxy": {
          "type": [
            "string",
            "null"
          ]
        },
        "config": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProfileConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "gemlogin_profile_id"
      ],
      "additionalProperties": false
    },
    "ProfileDeleteCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "profile.delete"
        },
        "gemlogin_profile_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name",
        "gemlogin_profile_id"
      ],
      "additionalProperties": false
    },
    "LoginRunCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "login.run"
        },
        "profile_id": {
          "type": "string",
          "format": "uuid"
        },
        "gemlogin_profile_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "platform": {
          "type": "string",
          "enum": [
            "TIKTOK",
            "FACEBOOK",
            "TWITTER",
            "YOUTUBE"
          ]
        },
        "method": {
          "type": "string",
          "enum": [
            "COOKIE",
            "INFO"
          ]
        },
        "cookie": {
          "type": [
            "string",
            "null"
          ]
        },
        "username": {
          "type": [
            "string",
            "null"
          ]
        },
        "password": {
          "type": [
            "string",
            "null"
          ]
        },
        "otp_secret": {
          "type": [
            "string",
            "null"
          ]
        },
        "confirm_username": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "profile_id",
        "platform",
        "method"
      ],
      "additionalProperties": false
    },
    "CdpForwardCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "cdp.forward"
        },
        "action": {
          "type": "string",
          "enum": [
            "START",
            "STOP"
          ]
        },
        "session_id": {
          "type": "string",
          "format": "uuid"
        },
        "profile_id": {
          "anyOf": [
            {
              "type": "string",
              "format": "uuid"
            },
            {
              "type": "null"
            }
          ]
        },
        "gemlogin_profile_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "action",
        "session_id"
      ],
      "additionalProperties": false
    },
    "ServerCommand": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "command"
        },
        "command_id": {
          "type": "string",
          "format": "uuid"
        },
        "command": {
          "anyOf": [
            {
              "$ref": "#/definitions/RunCommand"
            },
            {
              "$ref": "#/definitions/BrowserOpenCommand"
            },
            {
              "$ref": "#/definitions/BrowserCloseCommand"
            },
            {
              "$ref": "#/definitions/ProfileCreateCommand"
            },
            {
              "$ref": "#/definitions/ProfileUpdateCommand"
            },
            {
              "$ref": "#/definitions/ProfileDeleteCommand"
            },
            {
              "$ref": "#/definitions/LoginRunCommand"
            },
            {
              "$ref": "#/definitions/CdpForwardCommand"
            }
          ]
        }
      },
      "required": [
        "type",
        "command_id",
        "command"
      ],
      "additionalProperties": false
    },
    "RegisteredMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "registered"
        },
        "station_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "type",
        "station_id"
      ],
      "additionalProperties": false
    },
    "CheckJobMessage": {
      "type": "object",
      "properties": {
        "trace_id": {
          "type": "string",
          "format": "uuid"
        },
        "job_id": {
          "type": "string",
          "format": "uuid"
        },
        "target_url": {
          "type": "string"
        },
        "url_hash": {
          "type": "string"
        },
        "platform": {
          "type": "string",
          "enum": [
            "TIKTOK",
            "FACEBOOK",
            "TWITTER",
            "YOUTUBE"
          ]
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "required": [
        "trace_id",
        "job_id",
        "target_url",
        "url_hash",
        "platform"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
