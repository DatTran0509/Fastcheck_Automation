{
  "type": "object",
  "properties": {},
  "additionalProperties": false,
  "description": "FastCheck WS/queue message definitions",
  "definitions": {
    "StationInfo": {
      "type": "object",
      "properties": {
        "station_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mac_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "ip_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "agent_version": {
          "type": "string",
          "minLength": 1
        },
        "max_concurrency": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "station_id",
        "name",
        "agent_version",
        "max_concurrency"
      ],
      "additionalProperties": false
    },
    "StationProfile": {
      "type": "object",
      "properties": {
        "gemlogin_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "platform": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "TIKTOK",
                "FACEBOOK",
                "TWITTER",
                "YOUTUBE"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "gem_status": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "gemlogin_profile_id"
      ],
      "additionalProperties": false
    },
    "RegisterMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "register"
