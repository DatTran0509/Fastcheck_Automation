        "station": {
          "$ref": "#/definitions/StationInfo"
        }
      },
      "required": [
        "type",
        "station"
      ],
      "additionalProperties": false
    },
    "HeartbeatMessage": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "heartbeat"
