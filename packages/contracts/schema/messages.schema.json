        "ts": {
          "type": "string"
        },
        "ram_mb": {
          "type": [
            "number",
            "null"
          ]
        },
        "cpu_percent": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "required": [
        "type",
        "station_id",
        "current_load",
        "ts"
