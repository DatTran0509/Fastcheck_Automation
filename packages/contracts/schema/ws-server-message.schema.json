{
  "anyOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "command"
        },
        "command_id": {
          "type": "string",
          "format": "uuid"
        },
        "command": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "script.run"
                },
                "trace_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "job_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "target_url": {
                  "type": "string"
                },
                "platform": {
                  "type": "string",
                  "enum": [
                    "TIKTOK",
                    "FACEBOOK",
                    "TWITTER",
                    "YOUTUBE"
                  ]
                },
                "profile_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "cookie": {
                  "type": "string"
                }
              },
              "required": [
                "name",
                "trace_id",
                "job_id",
                "target_url",
                "platform",
                "profile_id",
                "cookie"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "browser.open"
                },
                "profile_id": {
                  "type": "string",
                  "format": "uuid"
                }
              },
              "required": [
                "name",
                "profile_id"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "browser.close"
                },
                "profile_id": {
                  "type": "string",
                  "format": "uuid"
                }
              },
              "required": [
                "name",
                "profile_id"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "type",
        "command_id",
        "command"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "registered"
        },
        "station_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "type",
        "station_id"
      ],
      "additionalProperties": false
    }
  ],
  "$schema": "http://json-schema.org/draft-07/schema#"
}
